{
  "name": "ninjabazaar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && prisma generate && next build",
    "build:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && npm run build",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "start": "node scripts/start-production.cjs",
    "lint": "next lint",
    "server": "nodemon server/server.ts --watch server/server.ts",
    "escrow-cron": "ts-node --esm scripts/cron.ts",
    "test-escrow": "ts-node --esm scripts/test-escrow-flow.ts",
    "immediate-release": "ts-node --esm scripts/immediate-release.ts",
    "auto-complete": "ts-node --esm scripts/auto-complete.ts"
  },
