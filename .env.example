# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # publishable key (client-safe)

# Server-side uploads — REQUIRED for product image upload
# Get from: Supabase Dashboard → Project Settings → API Keys → Secret key
SUPABASE_SECRET_KEY=sb_secret_...
# OR legacy service role JWT:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# NextAuth — REQUIRED for login/sessions (local + Vercel production)
NEXTAUTH_SECRET=your-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — required if Google sign-in is enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://...

# Debug auth redirects on Vercel (optional)
# AUTH_DEBUG=true
