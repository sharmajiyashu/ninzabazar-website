# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # publishable key (client-safe)

# Server-side uploads — REQUIRED for product image upload
# Get from: Supabase Dashboard → Project Settings → API Keys → Secret key
SUPABASE_SECRET_KEY=sb_secret_...
# OR legacy service role JWT:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
