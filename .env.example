# =============================================================================
# Ninja Bazaar — Environment Variables
# =============================================================================
# LOCAL:  Copy this file to `.env` and fill in real values
# LIVE:   Add the same variables in Vercel → Project → Settings → Environment Variables
#         Do NOT commit `.env` to git — it is in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# App URL (auth + cron jobs)
# -----------------------------------------------------------------------------
# LOCAL
NEXTAUTH_URL=http://localhost:3000

# Server / PM2 — port Next.js listens on (read by ecosystem.config.cjs)
# Do NOT use 6000 here — Next.js blocks it. Use 6100 (or 3000, 8080, etc.)
# For public URL :6000, set PUBLIC_PORT=6000 and Nginx proxy 6000 → PORT below
PORT=6100
PUBLIC_PORT=6000

# Optional PM2 settings
# PM2_APP_NAME=ninjabazaar
# PM2_MAX_MEMORY=1G
# NODE_ENV=production

# LIVE (Vercel) — set in Vercel dashboard for Production:
# NEXTAUTH_URL=https://ninzabazar-website.vercel.app
# Note: On Vercel, NEXTAUTH_URL is also auto-detected from the request host.
#       Still recommended to set it explicitly for Production.

# -----------------------------------------------------------------------------
# NextAuth — REQUIRED for login / sessions
# -----------------------------------------------------------------------------
# Generate a strong secret (run once, use same value local + live):
#   openssl rand -base64 32
# NEVER use dummy values on production.
NEXTAUTH_SECRET=

# Optional: set AUTH_DEBUG=true in Vercel to log auth issues in deployment logs
# AUTH_DEBUG=true

# -----------------------------------------------------------------------------
# Database (Supabase Postgres + Prisma)
# -----------------------------------------------------------------------------
# Use Supabase → Project Settings → Database → Connection string
# DATABASE_URL  = Transaction pooler (port 6543, ?pgbouncer=true)
# DIRECT_URL    = Session pooler / direct (port 5432) — required for migrations
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Storage (product images)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Server-side uploads — use service role OR secret key (one of these is required)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
# SUPABASE_SECRET_KEY=sb_secret_...

# -----------------------------------------------------------------------------
# Google OAuth — REQUIRED (app throws error if missing)
# -----------------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI (LIVE):
#   https://ninzabazar-website.vercel.app/api/auth/callback/google
# Authorized redirect URI (LOCAL):
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Razorpay (payments)
# -----------------------------------------------------------------------------
# LIVE: use Razorpay Dashboard → Live mode keys
# TEST: use Test mode keys for local development
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (signup verification, seller registration)
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM="Ninja Bazaar" <noreply@yourdomain.com>

# Optional — used in email templates
# COMPANY_NAME=Ninja Bazaar

# -----------------------------------------------------------------------------
# Cron / scheduled jobs (escrow release, auto-complete orders)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
CRON_SECRET_TOKEN=

# -----------------------------------------------------------------------------
# Do NOT set on Vercel (Vercel sets these automatically)
# -----------------------------------------------------------------------------
# NODE_ENV=production
# VERCEL=1
